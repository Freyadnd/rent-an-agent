# OWS wallet name (created via: ows wallet create --name agent-wallet)
OWS_WALLET_NAME=agent-wallet

# Base RPC (free: https://base.llamarpc.com or Alchemy/Infura)
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# USDC on Base (no need to change)
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Contract addresses — fill in after `forge script Deploy`
REGISTRY_ADDRESS=0x
VAULT_ADDRESS=0x
SUBSCRIPTION_ADDRESS=0x

# Your agent's ID in the registry (returned after registerAgent())
AGENT_ID=1

# Sweeper EOA private key (separate from OWS wallet, this is the on-chain tx signer)
# Generate with: cast wallet new
SWEEPER_PRIVATE_KEY=0x

# Sweep when USDC balance exceeds this amount (in USDC, not wei)
SWEEP_THRESHOLD_USDC=10

# How often to check and sweep (minutes)
SWEEP_INTERVAL_MINUTES=15

# Express server port
PORT=3001

# Admin API key for /admin/* endpoints
AGENT_API_KEY=change-me-in-production
